---
import Base from "../layouts/Base.astro";
import { site, serviceNav, areaNav, counties, IMG } from "../data/site.js";
import { itemListNode, faqNode, breadcrumb } from "../lib/schema.js";

const problems = [
  { label: "Rats in the attic", glyph: "i-home", slug: "attic-rat-cleanup-in-cincinnati" },
  { label: "Scratching in walls", glyph: "i-rat", slug: "rat-control-in-cincinnati" },
  { label: "Burrows in the yard", glyph: "i-seal", slug: "rat-removal-in-cincinnati" },
  { label: "Droppings in kitchen", glyph: "i-target", slug: "rat-exterminator-in-cincinnati" },
  { label: "Rats in the basement", glyph: "i-trap", slug: "rat-removal-in-cincinnati" },
  { label: "Chewed wires", glyph: "i-alert", slug: "rat-exterminator-in-cincinnati" },
  { label: "Dead rat smell", glyph: "i-alert", slug: "dead-rat-removal-in-cincinnati" },
  { label: "Mice, not rats", glyph: "i-mouse", slug: "mouse-control-in-cincinnati" },
  { label: "Seal them out", glyph: "i-shield", slug: "rodent-exclusion-in-cincinnati" },
  { label: "Not sure what it is", glyph: "i-search", slug: "rat-inspection-in-cincinnati" },
];

const svcBlurb = {
  "rat-control-in-cincinnati": "Norway rats worked from every angle: sewers, hillside burrows, basements, and walls, found, removed, and sealed out in order.",
  "rat-exterminator-in-cincinnati": "Trapping on the runways rats actually use, placed safely around kids and pets, then the gaps sealed with metal.",
  "rat-removal-in-cincinnati": "Live rats out of the basement, walls, garage, and yard, with the hillside burrows worked so the house stops refilling.",
  "rat-inspection-in-cincinnati": "The flashlight-first visit: what rodent, where it enters, how far it has spread. Every good rat job starts here.",
  "rodent-exclusion-in-cincinnati": "The sealing that makes removal permanent. Galvanized mesh and sheet metal at foundations, drains, and utility gaps.",
  "attic-rat-cleanup-in-cincinnati": "Nests, soiled insulation, and droppings cleared and disinfected, then the climb routes closed for good.",
  "dead-rat-removal-in-cincinnati": "The source of that smell located in a wall or attic, removed, and deodorized, then the entry points sealed.",
  "commercial-rat-control-in-cincinnati": "Documented programs for OTR restaurants, warehouses, and multi-unit buildings that hold up to health-code pressure.",
  "mouse-control-in-cincinnati": "House mice trapped out of kitchens and walls, and the dime-sized gaps mouse-proofed before the fall push.",
};
const svcAlt = {
  "rat-control-in-cincinnati": "Norway rat beside a stone foundation gap on an older Cincinnati home",
  "rat-exterminator-in-cincinnati": "A local rat exterminator setting a snap trap along a Cincinnati basement wall",
  "rat-removal-in-cincinnati": "Snap trap set on a rat runway near a Cincinnati basement floor drain",
  "rat-inspection-in-cincinnati": "Flashlight inspection of an old Cincinnati stone foundation for rat entry points",
  "rodent-exclusion-in-cincinnati": "Hardware cloth sealing a foundation gap on a Cincinnati brick home",
  "attic-rat-cleanup-in-cincinnati": "Contaminated attic insulation and rat droppings cleared in a Cincinnati home",
  "dead-rat-removal-in-cincinnati": "A technician locating a dead rat odor inside a Cincinnati wall",
  "commercial-rat-control-in-cincinnati": "Exterior rodent monitoring station at a Cincinnati commercial building",
  "mouse-control-in-cincinnati": "House mouse squeezing through a small gap along a Cincinnati foundation",
};

const faqs = [
  { q: "What kind of rats are in Cincinnati?", a: "Almost always Norway rats, the big brown ground-level burrowers. They thrive on the city's very old combined sewer system, surface through floor drains and cleanouts, and dig burrows along foundations and hillsides, then climb into basements and walls. Roof rats are uncommon in the metro." },
  { q: "How do I get rid of rats for good?", a: "Follow the order that works: inspect, remove, then seal. Trapping alone lowers the count, but rats come back through the same gaps unless those openings get closed with metal. A local exterminator maps the entry points, traps the active rats, and seals the property so new ones cannot follow the trail." },
  { q: "How much does rat control cost in Cincinnati?", a: "It depends on how far the rats have spread and how many entry points need sealing, which matters on hillside lots, so a flat website price would be a guess. A local exterminator looks at the property and gives upfront pricing before any work starts. Call 513-286-5607 to set up a visit." },
  { q: "Are the noises in my walls rats or mice?", a: "Mice sound like light, fast scratching, usually up in the walls and ceilings. Rats sound heavier, with thumps and gnawing low in the structure, and they leave larger droppings and outdoor burrows. A rat inspection confirms which one you have and sets the right plan." },
  { q: "Why do I get mice every fall?", a: "House mice push indoors from October through March when overnight lows drop below 50 degrees, looking for warmth and food. Older Cincinnati homes with stone foundations and 19th-century brick make the move easy, so the same house sees mice each fall until the dime-sized gaps get sealed." },
  { q: "Do you cover Northern Kentucky too?", a: "Yes. Coverage runs across the whole metro on both sides of the Ohio River: Hamilton, Butler, Warren, and Clermont counties in Ohio, plus Kenton, Campbell, and Boone counties in Northern Kentucky. Call 513-286-5607 and a local exterminator can confirm your neighborhood in a minute." },
];

const nodes = [
  itemListNode(serviceNav),
  faqNode(faqs),
  breadcrumb([{ name: "Home", path: "/" }]),
];
---
<Base
  title="Rat Control in Cincinnati, OH | Rats & Mice"
  description="Rat control in Cincinnati, OH. Norway rats and mice handled with inspection, trapping, and metal sealing. Answered day or night. Call 513-286-5607."
  path="/"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(nodes)} />

  <!-- HERO -->
  <section class="hero">
    <span class="leafblob l1"></span><span class="leafblob l2"></span>
    <div class="wrap hero-grid">
      <div>
        <span class="kicker"><span class="dot"></span> Cincinnati's rat &amp; rodent specialists</span>
        <h1>Rat Control in Cincinnati, OH</h1>
        <p class="lede">Scratching in the walls at 2 a.m.? Burrows along a hillside foundation? Rat control in Cincinnati is what this line is for. A local exterminator handles Norway rats and mice the right way: find the entry, clear the rats, seal the building with metal.</p>
        <div class="hero-cta">
          <a class="btn-call" href={site.phoneHref}><svg><use href="#i-phone"/></svg><span>{site.phone}<small>Tap to call · Answered day or night</small></span></a>
          <a class="btn-ghost" href="/how-it-works/">How it works →</a>
        </div>
        <div class="hero-chips">
          <span>No obligation</span>
          <span>Upfront estimate</span>
          <span>Metal sealing, not foam</span>
          <span>Rats only, done right</span>
        </div>
      </div>
      <div class="hero-photo">
        <div class="frame"><img src={IMG.hero} alt="The Cincinnati riverfront skyline and the Ohio River bridges" width="480" height="600" loading="eager" fetchpriority="high" /></div>
        <span class="tag">SERVING GREATER CINCINNATI · OH &amp; KY</span>
        <div class="float f1"><svg><use href="#i-clock"/></svg> Answered day or night</div>
        <div class="float f2"><svg><use href="#i-shield"/></svg> Sealed to stay out</div>
      </div>
    </div>
    <svg class="hero-torn" viewBox="0 0 1440 54" preserveAspectRatio="none" aria-hidden="true"><path fill="#ffffff" d="M0 54h1440V22c-40 6-92-8-142-4-53 4-86 14-138 12-58-3-92-16-150-14-52 2-84 15-136 16-56 1-96-14-152-13-52 1-88 15-140 15-58 0-96-16-154-13-50 3-84 14-134 12V54Z"/></svg>
  </section>

  <!-- PROBLEM PICKER -->
  <div class="picker"><div class="wrap">
    <div class="p-head">
      <h2>What kind of rat problem are you having?</h2>
      <p>Tap what you are seeing and jump straight to the fix. Not sure? Start with an inspection.</p>
    </div>
    <div class="chip-grid">
      {problems.map((p) => (
        <a class="chip" href={`/${p.slug}/`}><svg><use href={`#${p.glyph}`}/></svg>{p.label}</a>
      ))}
    </div>
  </div></div>

  <!-- CTA BAR -->
  <div class="cta-bar"><div class="wrap">
    <strong>Rats do not wait. Neither does this line.</strong>
    <a class="num" href={site.phoneHref}>{site.phone}</a>
    <a class="mini" href="/contact/">Or reach out here →</a>
  </div></div>

  <!-- SPLIT INTRO + CALL CARD -->
  <section><div class="wrap split">
    <div class="prose-lite">
      <span class="kicker"><span class="dot"></span> Rat control done right in Cincinnati</span>
      <h2>Norway Rats Are a Cincinnati Problem</h2>
      <p>Cincinnati gives Norway rats nearly everything they want. The city runs one of the oldest combined sewer systems in the country, and brown rats travel those laterals the way people use streets, surfacing through floor drains and broken cleanouts. Add the seven hills, where terraced yards and old stone retaining walls give burrows endless harborage, and the 19th-century brick of Over-the-Rhine, Hyde Park, Walnut Hills, and Price Hill, and the pattern repeats block after block.</p>
      <p>Rats are a property-wide problem, not one animal in one trap. A single burrow in one yard usually means rats are working several lots at once, and store-bought bait left in a corner will not touch a colony feeding off the sewer. Real rat control follows a set order: inspect, remove, then seal. Skip the sealing and the rats are back within weeks, up the same lateral through the same open gap.</p>
      <p>That last step is where most jobs fall apart. Rats chew through spray foam and steel wool in a single night, so a foam patch just marks the spot for the next rat. A local exterminator seals with galvanized mesh, hardware cloth, and sheet metal, materials rat teeth cannot beat, so the removal holds through a freeze-thaw winter. Start with a <a href="/rat-inspection-in-cincinnati/">rat inspection</a>, then move to <a href="/rat-removal-in-cincinnati/">removal</a> and <a href="/rodent-exclusion-in-cincinnati/">exclusion</a> in order.</p>
    </div>
    <div class="callcard">
      <h3>Get rats handled today</h3>
      <p>One call reaches a local rat exterminator who works Cincinnati rodents only. Describe what you are seeing or hearing and get an honest read.</p>
      <a class="btn-call" href={site.phoneHref}><svg><use href="#i-phone"/></svg><span>{site.phone}<small>Answered day or night</small></span></a>
      <ul>
        <li><svg><use href="#i-check"/></svg> Upfront estimate before any work, no obligation</li>
        <li><svg><use href="#i-check"/></svg> Norway rats, mice, attic cleanup, and dead rat removal</li>
        <li><svg><use href="#i-check"/></svg> Metal sealing that survives freeze-thaw winters</li>
        <li><svg><use href="#i-check"/></svg> Serving the whole metro, Ohio and Northern Kentucky</li>
      </ul>
    </div>
  </div></section>

  <!-- FEATURE ROW -->
  <section class="wash"><div class="wrap">
    <div class="sec-head">
      <span class="kicker"><span class="dot"></span> Why homeowners call</span>
      <h2>A Rat Service Built for This City</h2>
    </div>
    <div class="feat-grid">
      <div class="feat"><span class="ic"><svg><use href="#i-clock"/></svg></span><div><h3>Call day or night</h3><p>Rats work after dark and so does the phone. Reach a local rat exterminator when you hear it, not next business day.</p></div></div>
      <div class="feat"><span class="ic"><svg><use href="#i-search"/></svg></span><div><h3>Inspect before you treat</h3><p>Every job starts with confirming the species and mapping the entry points, so the plan fits the problem instead of guessing.</p></div></div>
      <div class="feat"><span class="ic"><svg><use href="#i-shield"/></svg></span><div><h3>Metal, not foam</h3><p>Sealing done with galvanized mesh and sheet metal, the part most DIY attempts skip and the reason rats come back.</p></div></div>
      <div class="feat"><span class="ic"><svg><use href="#i-rat"/></svg></span><div><h3>Rats only, done right</h3><p>No spray-everything pest route and no upsell into services you did not call about. One problem, worked until it is done.</p></div></div>
    </div>
  </div></section>

  <!-- SPECIES BAND -->
  <section class="band"><div class="wrap">
    <div class="sec-head">
      <span class="kicker"><span class="dot"></span> Know your rodent</span>
      <h2>The Two Rodents That Matter Here</h2>
      <p>No roof rats in Cincinnati. The pressure comes from the ground, the sewers, and the fall cold, and the fix is different for each animal.</p>
    </div>
    <div class="species">
      <div class="spec-card">
        <span class="glyph"><svg><use href="#i-rat"/></svg></span>
        <h3>The Norway Rat</h3>
        <span class="latin">RATTUS NORVEGICUS · GROUND LEVEL</span>
        <p>A heavy burrower that works the metro from below: burrows along foundations, terraced yards, and retaining walls, travel through the old combined sewers, and entries through floor drains, cleanouts, and gaps in stone and brick. Strongest in the older, denser neighborhoods.</p>
        <ul>
          <li>Burrow holes with fresh soil at the foundation, stoop, or retaining wall</li>
          <li>Dark, tapered droppings the size of a large grain of rice</li>
          <li>Thumping or gnawing low in the house at night</li>
        </ul>
      </div>
      <div class="spec-card">
        <span class="glyph"><svg><use href="#i-mouse"/></svg></span>
        <h3>The House Mouse</h3>
        <span class="latin">MUS MUSCULUS · EVERYWHERE ELSE</span>
        <p>Cincinnati's most common rodent call. Mice need a gap the size of a dime, and older brick homes and new subdivisions both offer plenty. They push indoors with the first hard cold in October and winter inside wall voids, kitchens, and basements.</p>
        <ul>
          <li>Rice-sized droppings in drawers, under sinks, along baseboards</li>
          <li>Light, fast scratching in walls and ceilings at night</li>
          <li>Chewed packaging in the pantry, nesting in stored fabric</li>
        </ul>
      </div>
    </div>
  </div></section>

  <!-- SERVICES GRID -->
  <section><div class="wrap">
    <div class="sec-head">
      <span class="kicker"><span class="dot"></span> Rat &amp; rodent services</span>
      <h2>Rat Control Services in Cincinnati</h2>
      <p>One problem, handled end to end. Every job runs inspection first, removal second, sealing third, because that order is what makes it permanent.</p>
    </div>
    <div class="svc-grid">
      {serviceNav.map((s) => (
        <article class="svc">
          <img src={IMG[s.slug]} alt={svcAlt[s.slug]} width="380" height="214" loading="lazy" />
          <div class="svc-body">
            <h3><a href={`/${s.slug}/`}>{s.label}</a></h3>
            <p>{svcBlurb[s.slug]}</p>
            <span class="go">See the service →</span>
          </div>
        </article>
      ))}
    </div>
  </div></section>

  <!-- PROCESS -->
  <section class="wash"><div class="wrap">
    <div class="sec-head">
      <span class="kicker"><span class="dot"></span> The process</span>
      <h2>How a Rat Job Runs</h2>
      <p>The order is the method. Skip a step and the problem comes back with the next cold front.</p>
    </div>
    <div class="proc">
      <ol>
        <li><div><b>1. Describe It</b><span>Call and say what you are seeing and hearing. You get an honest read and an upfront estimate before anything is scheduled.</span></div></li>
        <li><div><b>2. Inspect</b><span>A local exterminator confirms the species and maps every entry point, from the foundation and drains to the roofline.</span></div></li>
        <li><div><b>3. Remove</b><span>Traps and secured stations placed on the runways rats actually use, chosen and positioned around kids and pets.</span></div></li>
        <li><div><b>4. Seal</b><span>Entry points closed with metal that survives rat teeth and freeze-thaw winters. This is the step that lasts.</span></div></li>
        <li><div><b>5. Confirm</b><span>A follow-up reads the evidence: activity gone, seals holding, and guidance for keeping it that way.</span></div></li>
      </ol>
      <div class="proc-art">
        <img src={IMG["rat-inspection-in-cincinnati"]} alt="A local technician inspecting a Cincinnati home for rat entry points" width="560" height="440" loading="lazy" />
      </div>
    </div>
    <div class="hero-cta" style="justify-content:center;margin-top:30px"><a class="btn-ghost" href="/how-it-works/">The full process, explained →</a></div>
  </div></section>

  <!-- VALUE CARDS -->
  <section><div class="wrap">
    <div class="sec-head">
      <span class="kicker"><span class="dot"></span> What you get on the call</span>
      <h2>Straightforward From the First Ring</h2>
      <p>No pressure and no games. Here is what a call to a local Cincinnati rat exterminator actually gets you.</p>
    </div>
    <div class="value-grid">
      <div class="value-card"><div class="vk">No obligation</div><h3>Describe the Problem Free</h3><p>Tell the exterminator what you are seeing or hearing and get an honest read on what the fix takes. You decide where it goes from there.</p></div>
      <div class="value-card"><div class="vk">Upfront pricing</div><h3>An Estimate, Not a Guess</h3><p>The number comes after the property is seen, so it fits your house instead of a one-size website price. No surprises added later.</p></div>
      <div class="value-card"><div class="vk">Built to last</div><h3>Sealed With Metal</h3><p>Removal paired with exclusion, sealed in galvanized mesh and sheet metal so the rats do not simply return next winter.</p></div>
    </div>
  </div></section>

  <!-- PROMISES -->
  <section class="wash"><div class="wrap">
    <div class="sec-head">
      <span class="kicker"><span class="dot"></span> How it works</span>
      <h2>Two Simple Commitments</h2>
    </div>
    <div class="promises">
      <div class="promise p-leaf"><span class="big">Day or Night</span><small>One Call Away</small><p>The line is answered day or night, so you can reach a local exterminator when the scratching starts.</p></div>
      <div class="promise p-forest"><span class="big">Seal</span><small>Then Confirm</small><p>Removal is paired with metal sealing and a follow-up, so the fix holds instead of resetting each winter.</p></div>
    </div>
  </div></section>

  <!-- NEIGHBOR / WHY BAND -->
  <section class="band"><div class="wrap neighbor">
    <div>
      <span class="kicker"><span class="dot"></span> Built for Cincinnati housing</span>
      <h2>A Local Read on Every Block</h2>
      <p>Cincinnati rat pressure changes with the housing. Century brick in Over-the-Rhine and the West End hides entry points in stone foundations, old coal chutes, and open wall cavities. Hillside homes in Mount Adams, Mount Auburn, and Price Hill sit at grade on the downhill side, an easy door. New subdivisions in Mason and West Chester still leak through construction gaps. And every freeze-thaw winter opens fresh cracks a rat can use.</p>
      <ul class="trust-points">
        <li><svg><use href="#i-check"/></svg> A local exterminator who reads the difference between a sewer-fed Norway rat run and a fall mouse push</li>
        <li><svg><use href="#i-check"/></svg> Entry points sealed with metal, aimed at the openings that actually matter on your home</li>
        <li><svg><use href="#i-check"/></svg> Work credited to the local pro who does it, with an upfront estimate before any of it starts</li>
      </ul>
      <div class="hero-cta" style="margin-top:22px"><a class="btn-call" href={site.phoneHref}><svg><use href="#i-phone"/></svg><span>{site.phone}<small>Answered day or night</small></span></a></div>
    </div>
    <div style="display:flex;justify-content:center">
      <svg viewBox="0 0 160 160" role="img" aria-label="Cincinnati rat control service seal" style="width:220px;height:220px">
        <circle cx="80" cy="80" r="76" fill="#24462f" stroke="#8cc63f" stroke-width="3"/>
        <circle cx="80" cy="80" r="60" fill="none" stroke="#335a41" stroke-width="1.5"/>
        <path d="M74 122A20 20 0 0 1 54 102c0-16 20-25 42-27 0 22-9 41-22 47z" fill="none" stroke="#8cc63f" stroke-width="3" stroke-linejoin="round"/>
        <g fill="#e7f0e0"><circle cx="70" cy="96" r="6"/><circle cx="65" cy="91" r="2.4"/><circle cx="75" cy="91" r="2.4"/></g>
        <path d="M78 96c7 0 9.5 1.6 12 4.5" fill="none" stroke="#e7f0e0" stroke-width="2.4" stroke-linecap="round"/>
        <text x="80" y="34" text-anchor="middle" fill="#8cc63f" font-family="Fraunces, serif" font-weight="700" font-size="12" letter-spacing="1">CINCINNATI</text>
        <text x="80" y="140" text-anchor="middle" fill="#e7f0e0" font-family="Fraunces, serif" font-weight="700" font-size="10" letter-spacing="2">RATS ONLY</text>
      </svg>
    </div>
  </div></section>

  <!-- SERVICE AREA -->
  <section><div class="wrap">
    <div class="sec-head">
      <span class="kicker"><span class="dot"></span> Where we work</span>
      <h2>Serving the Cincinnati Metro</h2>
      <p>Rat pressure does not stop at the river, and neither does the coverage. Ohio and Northern Kentucky, urban core to the county edges.</p>
    </div>
    <div class="split" style="align-items:start">
      <div class="counties">
        {counties.map((c, i) => (
          <details class="county" open={i === 0}>
            <summary>{c.name}<span class="pm">+</span></summary>
            <div class="county-body">
              {c.places.map((p) => <span><svg width="14" height="14" style="color:#24623a"><use href="#i-pin"/></svg> {p}</span>)}
            </div>
          </details>
        ))}
      </div>
      <div class="metro-map">
        <svg viewBox="0 0 420 360" role="img" aria-label="Stylized map of the Cincinnati metro across the Ohio River into Northern Kentucky">
          <rect width="420" height="360" fill="#24462f"/>
          <g opacity="0.3" stroke="#335a41" stroke-width="1"><path d="M0 90h420M0 180h420M0 270h420M105 0v360M210 0v360M315 0v360"/></g>
          <path d="M0 210 C90 190 150 232 220 212 C290 194 350 224 420 202" fill="none" stroke="#3f7fae" stroke-width="7" opacity="0.85"/>
          <text x="30" y="120" fill="#a9cb98" font-family="monospace" font-size="10">OHIO</text>
          <text x="300" y="300" fill="#a9cb98" font-family="monospace" font-size="10">KENTUCKY</text>
          <g fill="#2d6a3e" stroke="#3f7f4f" stroke-width="1.5">
            <rect x="150" y="130" width="110" height="70" rx="8"/>
            <rect x="60" y="70" width="90" height="70" rx="8"/>
            <rect x="270" y="90" width="80" height="70" rx="8"/>
            <rect x="150" y="240" width="110" height="70" rx="8"/>
          </g>
          <g font-family="Mulish, sans-serif" font-size="10" font-weight="800">
            <g fill="#8cc63f"><circle cx="205" cy="196" r="6"/></g><text x="214" y="200" fill="#e7f0e0">Cincinnati</text>
            <g fill="#8cc63f"><circle cx="240" cy="175" r="4.5"/></g><text x="248" y="178" fill="#c3d6ba">Norwood</text>
            <g fill="#8cc63f"><circle cx="255" cy="120" r="4.5"/></g><text x="263" y="123" fill="#c3d6ba">Blue Ash</text>
            <g fill="#8cc63f"><circle cx="300" cy="100" r="4.5"/></g><text x="285" y="92" fill="#c3d6ba">Mason</text>
            <g fill="#8cc63f"><circle cx="95" cy="95" r="4.5"/></g><text x="62" y="86" fill="#c3d6ba">Hamilton</text>
            <g fill="#8cc63f"><circle cx="200" cy="256" r="4.5"/></g><text x="150" y="250" fill="#c3d6ba">Covington</text>
            <g fill="#8cc63f"><circle cx="240" cy="270" r="4.5"/></g><text x="248" y="273" fill="#c3d6ba">Newport</text>
            <g fill="#8cc63f"><circle cx="165" cy="285" r="4.5"/></g><text x="120" y="300" fill="#c3d6ba">Florence</text>
          </g>
          <text x="20" y="345" fill="#7fa88f" font-family="monospace" font-size="9" letter-spacing="1">CINCINNATI METRO · OH &amp; KY</text>
        </svg>
      </div>
    </div>
    <div class="sec-head left" style="margin-top:44px;max-width:none">
      <h3 style="font-size:1.2rem">Popular Areas We Cover</h3>
    </div>
    <div class="area-links">
      {areaNav.map((a) => <a href={`/${a.slug}/`}><svg><use href="#i-pin"/></svg> {a.label}</a>)}
    </div>
    <p style="margin-top:24px;color:var(--muted)">Close to one of these? Coverage extends to the neighboring suburbs too: Sharonville, Montgomery, Milford, Lebanon, Fort Thomas, Erlanger, and Burlington among them. Call {site.phone} and ask. The answer is usually yes, and you will know in a minute. See the <a href="/service-areas/">full service area</a>.</p>
  </div></section>

  <!-- FAQ -->
  <section class="wash"><div class="wrap">
    <div class="sec-head">
      <span class="kicker"><span class="dot"></span> Rat control questions</span>
      <h2>Cincinnati Rat Control FAQ</h2>
    </div>
    <div class="faq">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
